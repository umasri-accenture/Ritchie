<Application x:Class="Richie.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Richie.UI"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Resources/DarkModeTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Brand semantic brushes (status triad). green = good, orange shades for all states. -->
            <SolidColorBrush x:Key="BrandSuccessBrush" Color="#57B894" />
            <SolidColorBrush x:Key="BrandWarningBrush" Color="#E6A756" />
            <SolidColorBrush x:Key="BrandDangerBrush" Color="#FFB366" />
            <SolidColorBrush x:Key="BrandPrimaryBrush" Color="#E6A756" />

            <!-- Light app background with subtle orange tint (warm whites). -->
            <LinearGradientBrush x:Key="BrandBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFFBF5" Offset="0" />
                <GradientStop Color="#FEF5E8" Offset="1" />
            </LinearGradientBrush>

            <!-- Warm Dark Mode Colors (not pure black, with orange undertones) -->
            <SolidColorBrush x:Key="DarkModeBackgroundBrush" Color="#2A2416" />
            <SolidColorBrush x:Key="DarkModeCardBrush" Color="#3A3228" />
            <SolidColorBrush x:Key="DarkModeSecondaryCardBrush" Color="#4A4236" />
            <SolidColorBrush x:Key="DarkModeTextBrush" Color="#F5F1E8" />
            <SolidColorBrush x:Key="DarkModeSecondaryTextBrush" Color="#E0D9CE" />
            <SolidColorBrush x:Key="DarkModeTertiaryTextBrush" Color="#B8AFA0" />
            <SolidColorBrush x:Key="DarkModeBorderBrush" Color="#524A3E" />
            <SolidColorBrush x:Key="DarkModeHoverBrush" Color="#4A4236" />

            <!-- Primary Button Colors (Soft Golden Orange) -->
            <SolidColorBrush x:Key="DarkModeButtonPrimaryBrush" Color="#E6A756" />
            <SolidColorBrush x:Key="DarkModeButtonPrimaryHoverBrush" Color="#D99F3E" />
            <SolidColorBrush x:Key="DarkModeButtonSecondaryBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="DarkModeButtonSecondaryHoverBrush" Color="#F8F4EC" />

            <!-- Sidebar Colors -->
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SidebarSelectedItemBrush" Color="#FFF3E3" />
            <SolidColorBrush x:Key="SidebarIndicatorBrush" Color="#E6A756" />
            <SolidColorBrush x:Key="SidebarHoverBrush" Color="#F8F4EC" />

            <!-- Richie AI Card Colors -->
            <SolidColorBrush x:Key="RichieAICardBackgroundBrush" Color="#F7F2FF" />
            <SolidColorBrush x:Key="RichieAICardBorderBrush" Color="#D9C7FF" />
            <SolidColorBrush x:Key="RichieAICardIconBrush" Color="#6D28D9" />
            <SolidColorBrush x:Key="RichieAICardTitleBrush" Color="#6D28D9" />

            <!-- Health Score Colors -->
            <SolidColorBrush x:Key="HealthScoreGreenBrush" Color="#57B894" />
            <SolidColorBrush x:Key="HealthScoreOrangeBrush" Color="#E6A756" />
            <SolidColorBrush x:Key="HealthScoreRedBrush" Color="#FFB366" />

            <!-- Light mode card backgrounds -->
            <SolidColorBrush x:Key="LightCardBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="LightCardAltBackgroundBrush" Color="#FFFBF5" />
            <SolidColorBrush x:Key="LightSubtleBackgroundBrush" Color="#FEF5E8" />

            <!-- Danger/Delete Button Color (Light Orange) -->
            <SolidColorBrush x:Key="DangerButtonBrush" Color="#FFB366" />

            <!-- Light Mode Text Overrides for Dark Theme -->
            <Style x:Key="DarkModeTextBlockStyle" TargetType="TextBlock">
                <Style.Triggers>
                    <Trigger Property="Background" Value="{x:Null}">
                        <Setter Property="Foreground" Value="{StaticResource DarkModeTextBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Style for ComboBox in Dark Mode -->
            <Style x:Key="DarkModeComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
                <Setter Property="Background" Value="{StaticResource DarkModeCardBrush}" />
                <Setter Property="Foreground" Value="{StaticResource DarkModeTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DarkModeBorderBrush}" />
            </Style>

            <!-- Style for CheckBox in Dark Mode -->
            <Style x:Key="DarkModeCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource DarkModeTextBrush}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <!-- Style for Button in Dark Mode -->
            <Style x:Key="DarkModeButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="{StaticResource DarkModeButtonSecondaryBrush}" />
                <Setter Property="Foreground" Value="{StaticResource DarkModeTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DarkModeBorderBrush}" />
            </Style>

            <!-- Secondary Button Style (White with border) -->
            <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="Foreground" Value="#374151" />
                <Setter Property="BorderBrush" Value="#D6D6D6" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <!-- Danger Button Style (Light Orange for Delete) -->
            <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Background" Value="#FFB366" />
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#FFB366" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
