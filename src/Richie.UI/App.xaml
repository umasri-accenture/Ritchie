<Application x:Class="Richie.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Richie.UI"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Brand semantic brushes (status triad). green = good, amber = attention, red = critical. -->
            <SolidColorBrush x:Key="BrandSuccessBrush" Color="#1FA56C" />
            <SolidColorBrush x:Key="BrandWarningBrush" Color="#DE9326" />
            <SolidColorBrush x:Key="BrandDangerBrush" Color="#CE2E20" />
            <SolidColorBrush x:Key="BrandPrimaryBrush" Color="#BE3A2F" />

            <!-- Soft-gold app background (gentle vertical gradient; white cards sit on top). -->
            <LinearGradientBrush x:Key="BrandBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F7EDD4" Offset="0" />
                <GradientStop Color="#E6CF97" Offset="1" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </Application.Resources>
</Application>
