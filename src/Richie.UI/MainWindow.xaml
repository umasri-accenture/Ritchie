<ui:FluentWindow x:Class="Richie.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Richie.UI"
        xmlns:pages="clr-namespace:Richie.UI.Views.Pages"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Richie"
        WindowState="Maximized"
        Width="1180" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid Background="{DynamicResource ApplicationBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Richie">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/richie-logo.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Topbar: notifications + profile -->
        <Grid Grid.Row="1" Height="48">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                <Grid>
                    <ui:Button x:Name="NotificationsButton" Appearance="Transparent" Click="OnNotificationsClick">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Alert24" />
                        </ui:Button.Icon>
                    </ui:Button>
                    <Border x:Name="BadgeBorder" Background="{DynamicResource SystemAttentionBrush}" CornerRadius="8" MinWidth="16" Height="16"
                            Padding="4,0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"
                            Visibility="Collapsed" IsHitTestVisible="False">
                        <TextBlock x:Name="BadgeText" Foreground="White" FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
                <ui:Button x:Name="ProfileButton" Appearance="Transparent" Margin="4,0,0,0" Click="OnProfileClick">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Person24" />
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>

            <Popup x:Name="NotificationsPopup" StaysOpen="False" AllowsTransparency="True"
                   Placement="Bottom" HorizontalOffset="-320" VerticalOffset="4"
                   PlacementTarget="{Binding ElementName=NotificationsButton}">
                <ui:Card Width="360" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                    <StackPanel>
                        <Grid>
                            <ui:TextBlock FontTypography="BodyStrong" Text="Notifications" VerticalAlignment="Center" />
                            <ui:Button HorizontalAlignment="Right" Appearance="Transparent" Padding="6,2"
                                       Content="Mark all read" Click="OnMarkAllRead" />
                        </Grid>
                        <ui:TextBlock x:Name="NotificationsEmpty" Appearance="Secondary" Margin="0,8,0,0"
                                      TextWrapping="Wrap" Text="You're all caught up." />
                        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="NotificationsList" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <ui:TextBlock FontTypography="BodyStrong" Text="{Binding Title}" />
                                                <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Text="{Binding Message}" />
                                                <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                                              Text="{Binding CreatedUtc, StringFormat=g}" />
                                            </StackPanel>
                                            <ui:Button Grid.Column="1" Appearance="Transparent" Padding="6,2"
                                                       Content="Dismiss" Tag="{Binding Id}" Click="OnDismissNotification" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </ui:Card>
            </Popup>

            <Popup x:Name="ProfilePopup" StaysOpen="False" AllowsTransparency="True"
                   Placement="Bottom" HorizontalOffset="-200" VerticalOffset="4"
                   PlacementTarget="{Binding ElementName=ProfileButton}">
                <ui:Card Width="240" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                    <StackPanel>
                        <ui:TextBlock x:Name="ProfileName" FontTypography="BodyStrong" Text="Signed in" />
                        <ui:TextBlock Appearance="Secondary" Text="Local account" />
                        <Separator Margin="0,8" />
                        <ui:Button Content="Profile" Appearance="Transparent" HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left" Click="OnProfileNavClick" />
                        <ui:Button Content="Backup &amp; restore" Appearance="Transparent" HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left" Click="OnBackupRestoreClick" />
                        <ui:Button Content="Settings" Appearance="Transparent" HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left" Click="OnSettingsClick" />
                        <ui:Button Content="Help" Appearance="Transparent" HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left" Click="OnHelpClick" />
                        <ui:Button Content="Log out" Appearance="Transparent" HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Left" Click="OnLogoutClick" />
                    </StackPanel>
                </ui:Card>
            </Popup>
        </Grid>

        <!-- Sidebar + content -->
        <ui:NavigationView x:Name="RootNavigation" Grid.Row="2"
                           PaneDisplayMode="Left"
                           OpenPaneLength="220"
                           Background="Transparent"
                           IsBackButtonVisible="Collapsed">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Dashboard" TargetPageType="{x:Type pages:DashboardPage}">
                    <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Home24" /></ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Assets" TargetPageType="{x:Type pages:AssetDocumentationPage}">
                    <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Wallet24" /></ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Expenses" TargetPageType="{x:Type pages:ExpenseTrackerPage}">
                    <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Money24" /></ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Password Vault" TargetPageType="{x:Type pages:PasswordVaultPage}">
                    <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="LockClosed24" /></ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Financial Health Audit" TargetPageType="{x:Type pages:FinancialHealthAuditPage}">
                    <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Heart24" /></ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Reports" TargetPageType="{x:Type pages:ReportsPage}">
                    <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Document24" /></ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Export" TargetPageType="{x:Type pages:ExportPage}">
                    <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Share24" /></ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>

        <!-- Draggable grip to resize the sidebar; sits on the pane's right edge (positioned in code-behind). -->
        <Thumb x:Name="PaneResizeGrip" Grid.Row="2" Width="6" Panel.ZIndex="50"
               HorizontalAlignment="Left" VerticalAlignment="Stretch"
               Cursor="SizeWE" DragDelta="OnPaneResize"
               ToolTip="Drag to resize the sidebar">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!-- Status bar: encryption · storage · last backup · auto-lock -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0" Padding="12,4"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="LockClosed24" FontSize="14" VerticalAlignment="Center" />
                <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Margin="4,0,16,0"
                              VerticalAlignment="Center" Text="AES-256 encrypted" />
                <ui:TextBlock x:Name="StatusStorage" Appearance="Secondary" FontTypography="Caption"
                              Margin="0,0,16,0" VerticalAlignment="Center" />
                <ui:TextBlock x:Name="StatusBackup" Appearance="Secondary" FontTypography="Caption"
                              Margin="0,0,16,0" VerticalAlignment="Center" />
                <ui:TextBlock x:Name="StatusLock" Appearance="Secondary" FontTypography="Caption"
                              VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- App tour overlay -->
        <Border x:Name="TourOverlay" Grid.RowSpan="4" Panel.ZIndex="100"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}" Opacity="0.6" Visibility="Collapsed">
            <ui:Card Width="440" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <ui:TextBlock x:Name="TourTitle" FontTypography="Subtitle" />
                    <ui:TextBlock x:Name="TourBody" Appearance="Secondary" TextWrapping="Wrap" Margin="0,8,0,16" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button x:Name="TourSkip" Content="Skip" Margin="0,0,8,0" Click="OnTourSkip" />
                        <ui:Button x:Name="TourNext" Content="Next" Appearance="Primary" Click="OnTourNext" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </Border>

        <!-- Toast host (overlays all rows) -->
        <ui:SnackbarPresenter x:Name="RootSnackbar" Grid.RowSpan="4" Panel.ZIndex="200" />
    </Grid>
</ui:FluentWindow>
