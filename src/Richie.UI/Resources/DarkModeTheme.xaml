<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!-- =====================================
         WARM DARK THEME
         Colors: Warm brown background (not pure black) with orange accents
         Accent: Soft Golden Orange (#E6A756) with light orange for status
         ===================================== -->

    <!-- Primary Dark Mode Colors: Warm browns (not pure black) with excellent contrast -->
    <Color x:Key="DarkBg">#2A2416</Color>               <!-- Main background: Warm brown -->
    <Color x:Key="DarkCardBg">#3A3228</Color>           <!-- Card/container background -->
    <Color x:Key="DarkSecondaryBg">#4A4236</Color>      <!-- Secondary container -->
    <Color x:Key="DarkTertiaryBg">#524A3E</Color>       <!-- Hover/tertiary -->
    <Color x:Key="DarkBorder">#5A524A</Color>           <!-- Border color -->
    <Color x:Key="DarkText">#F5F1E8</Color>             <!-- Primary text: Warm white -->
    <Color x:Key="DarkSecondaryText">#E0D9CE</Color>    <!-- Secondary text: Light warm gray -->
    <Color x:Key="DarkTertiaryText">#B8AFA0</Color>     <!-- Tertiary text/disabled -->
    <Color x:Key="DarkPlaceholder">#8A8278</Color>     <!-- Placeholder text -->

    <!-- Accent & Status Colors -->
    <Color x:Key="DarkAccent">#E6A756</Color>           <!-- Soft Golden Orange -->
    <Color x:Key="DarkAccentHover">#D99F3E</Color>      <!-- Darker Orange on hover -->
    <Color x:Key="DarkAccentActive">#CC8F2C</Color>     <!-- Active/pressed -->
    <Color x:Key="DarkSuccess">#57B894</Color>          <!-- Green success -->
    <Color x:Key="DarkWarning">#E6A756</Color>          <!-- Soft Orange warning -->
    <Color x:Key="DarkDanger">#FFB366</Color>           <!-- Light Orange danger (no red) -->

    <!-- Convert colors to brushes for easy reuse -->
    <SolidColorBrush x:Key="DarkBgBrush" Color="{StaticResource DarkBg}" />
    <SolidColorBrush x:Key="DarkCardBgBrush" Color="{StaticResource DarkCardBg}" />
    <SolidColorBrush x:Key="DarkSecondaryBgBrush" Color="{StaticResource DarkSecondaryBg}" />
    <SolidColorBrush x:Key="DarkTertiaryBgBrush" Color="{StaticResource DarkTertiaryBg}" />
    <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource DarkBorder}" />
    <SolidColorBrush x:Key="DarkTextBrush" Color="{StaticResource DarkText}" />
    <SolidColorBrush x:Key="DarkSecondaryTextBrush" Color="{StaticResource DarkSecondaryText}" />
    <SolidColorBrush x:Key="DarkTertiaryTextBrush" Color="{StaticResource DarkTertiaryText}" />
    <SolidColorBrush x:Key="DarkPlaceholderBrush" Color="{StaticResource DarkPlaceholder}" />
    <SolidColorBrush x:Key="DarkAccentBrush" Color="{StaticResource DarkAccent}" />
    <SolidColorBrush x:Key="DarkAccentHoverBrush" Color="{StaticResource DarkAccentHover}" />
    <SolidColorBrush x:Key="DarkAccentActiveBrush" Color="{StaticResource DarkAccentActive}" />
    <SolidColorBrush x:Key="DarkSuccessBrush" Color="{StaticResource DarkSuccess}" />
    <SolidColorBrush x:Key="DarkWarningBrush" Color="{StaticResource DarkWarning}" />
    <SolidColorBrush x:Key="DarkDangerBrush" Color="{StaticResource DarkDanger}" />


</ResourceDictionary>