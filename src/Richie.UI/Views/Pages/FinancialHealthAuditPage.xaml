<Page x:Class="Richie.UI.Views.Pages.FinancialHealthAuditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      mc:Ignorable="d"
      Title="Financial Health Audit"
      ScrollViewer.CanContentScroll="False"
      Loaded="OnLoaded">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Column="0" FontTypography="TitleLarge" Text="Financial Health Audit"
                          Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
            <ui:Button Grid.Column="1" HorizontalAlignment="Right" Content="Manage insurance" Click="OnManageInsurance" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ui:InfoBar Severity="Warning" IsOpen="{Binding ScoresAreInterim}" IsClosable="False"
                            Margin="0,0,0,12" Title="Interim scoring" Message="{Binding InterimNotice}" />

                <!-- Scores -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Card Grid.Column="0">
                        <StackPanel>
                            <ui:TextBlock Appearance="Secondary" Text="Portfolio Health Score" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:TextBlock FontTypography="Display" Foreground="{Binding HealthBrush}" Text="{Binding HealthScore}" />
                                <ui:TextBlock Appearance="Secondary" VerticalAlignment="Bottom" Margin="4,0,0,8" Text="/ 100" />
                            </StackPanel>
                            <ui:TextBlock FontTypography="Subtitle" Foreground="{Binding HealthBrush}" Text="{Binding HealthRating}" />
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption" TextWrapping="Wrap"
                                          Margin="0,4,0,8" Text="{Binding HealthScaleLegend}" />
                            <ItemsControl ItemsSource="{Binding HealthFactors}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <ui:TextBlock FontTypography="BodyStrong"
                                                          Text="{Binding Name}" />
                                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption" TextWrapping="Wrap"
                                                          Text="{Binding Explanation}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Column="2">
                        <StackPanel>
                            <ui:TextBlock Appearance="Secondary" Text="Risk Score (Riskometer)" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:TextBlock FontTypography="Display" Foreground="{Binding RiskBrush}" Text="{Binding RiskScore}" />
                                <ui:TextBlock Appearance="Secondary" VerticalAlignment="Bottom" Margin="4,0,0,8" Text="/ 100" />
                            </StackPanel>
                            <ui:TextBlock FontTypography="Subtitle" Foreground="{Binding RiskBrush}" Text="{Binding RiskBand}" />
                            <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding RiskScore}"
                                         Foreground="{Binding RiskBrush}" Margin="0,8,0,0" />
                            <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,8,0,0" Text="{Binding RiskInterpretation}" />
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption" TextWrapping="Wrap"
                                          Margin="0,8,0,0" Text="{Binding RiskScaleLegend}" />
                        </StackPanel>
                    </ui:Card>
                </Grid>

                <!-- Health dimensions radar -->
                <ui:Card Margin="0,0,0,12"
                         Visibility="{Binding HasAssets, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Health dimensions" />
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" TextWrapping="Wrap" Margin="0,0,0,8"
                                      Text="Each health-score factor on a 0–100 scale — a larger, more even shape is healthier." />
                        <lvc:PolarChart Height="320"
                                        Series="{Binding HealthRadarSeries}"
                                        AngleAxes="{Binding HealthRadarAngleAxes}"
                                        RadiusAxes="{Binding HealthRadarRadiusAxes}" />
                    </StackPanel>
                </ui:Card>

                <!-- Benchmark comparison -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong"
                                      Text="{Binding AgeBandName, StringFormat='Benchmark comparison — {0}'}" />
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Margin="0,2,0,8"
                                      Text="Your allocation vs the recommended range for your age group." />
                        <DataGrid ItemsSource="{Binding Benchmark}" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Asset class" Binding="{Binding ClassName}" Width="*" />
                                <DataGridTextColumn Header="Your allocation" Binding="{Binding ActualText}" Width="Auto" />
                                <DataGridTextColumn Header="Recommended" Binding="{Binding RecommendedText}" Width="Auto" />
                                <DataGridTemplateColumn Header="Status" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <ui:TextBlock Appearance="Secondary" Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding DiversificationText}" />
                    </StackPanel>
                </ui:Card>

                <!-- Goals + coverage -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Card Grid.Column="0">
                        <StackPanel>
                            <ui:TextBlock FontTypography="BodyStrong" Text="Goal progress" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding Goals}"
                                          Visibility="{Binding HasGoals, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <ui:TextBlock Text="{Binding Name}" />
                                            <ui:TextBlock HorizontalAlignment="Right" Appearance="Secondary"
                                                          Text="{Binding PercentComplete, StringFormat={}{0:0.#}%}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ui:TextBlock Appearance="Secondary" Text="No goals set yet."
                                          Visibility="{Binding NoGoals, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Column="2">
                        <StackPanel>
                            <ui:TextBlock FontTypography="BodyStrong" Text="Protection coverage" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding CoverageGaps}"
                                          Visibility="{Binding HasCoverageGaps, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,2" Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ui:TextBlock Appearance="Secondary" Text="Health and term-life cover are in place."
                                          Visibility="{Binding CoverageOk, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </ui:Card>
                </Grid>

                <!-- Compliance (§9.2) -->
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <ui:TextBlock FontTypography="BodyStrong" Text="Compliance" VerticalAlignment="Center" />
                            <ui:TextBlock HorizontalAlignment="Right" FontTypography="BodyStrong"
                                          Foreground="{Binding ComplianceBrush}" Text="{Binding ComplianceOverall}" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Compliance}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="{Binding Name}" />
                                        <ui:TextBlock Grid.Column="1" Appearance="Secondary" TextWrapping="Wrap" Text="{Binding Detail}" />
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ui:TextBlock FontTypography="BodyStrong" Margin="0,10,0,4" Text="Guaranteed investments"
                                      Visibility="{Binding HasGips, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <DataGrid ItemsSource="{Binding Gips}" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  Background="Transparent"
                                  Visibility="{Binding HasGips, Converter={StaticResource BoolToVisibilityConverter}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Plan" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Guaranteed %" Binding="{Binding GuaranteedReturnPercent}" Width="Auto" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ui:Card>

                <!-- Insights (cross-module: portfolio + spending) -->
                <ui:Card>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Insights" Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding Suggestions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,2" Text="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
