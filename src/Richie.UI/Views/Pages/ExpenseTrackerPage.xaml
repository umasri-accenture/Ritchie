<Page x:Class="Richie.UI.Views.Pages.ExpenseTrackerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      mc:Ignorable="d"
      Title="Expense Tracker">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Column="0" FontTypography="TitleLarge" Text="Expenses"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Analytics" Margin="0,0,6,0" Click="OnAnalytics" />
                <ui:Button Content="Recurring" Margin="0,0,6,0" Click="OnRecurring" />
                <ui:Button Content="Bulk upload" Margin="0,0,6,0" Click="OnBulkUpload" />
                <ui:Button Content="Income" Margin="0,0,6,0" Click="OnIncome" />
                <ui:Button Content="Add expense" Appearance="Primary" Click="OnAddExpense" />
            </StackPanel>
        </Grid>

        <!-- KPI cards + insights -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="0" Margin="0,0,10,0" MinHeight="92" VerticalAlignment="Stretch">
                <StackPanel Margin="6" VerticalAlignment="Stretch">
                    <ui:TextBlock Appearance="Secondary" Text="Spent This Month" />
                    <ui:TextBlock FontTypography="TitleLarge" Foreground="#2563EB" Text="{Binding CurrentMonthText}" />
                    <ui:TextBlock Appearance="Secondary" Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding MonthOverMonthText}" />
                </StackPanel>
            </ui:Card>

            <ui:Card Grid.Column="1" Margin="0,0,10,0" MinHeight="92" VerticalAlignment="Stretch">
                <StackPanel Margin="6" VerticalAlignment="Stretch">
                    <ui:TextBlock Appearance="Secondary" Text="Income This Month" />
                    <ui:TextBlock FontTypography="TitleLarge" Foreground="#0F766E" Text="{Binding IncomeThisMonthText}" />
                    <ui:TextBlock Appearance="Secondary" Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>

            <ui:Card Grid.Column="2" Margin="0,0,10,0" MinHeight="92" VerticalAlignment="Stretch">
                <StackPanel Margin="6" VerticalAlignment="Stretch">
                    <ui:TextBlock Appearance="Secondary" Text="Top Category" />
                    <ui:TextBlock FontTypography="BodyStrong" Margin="0,4,0,0" TextWrapping="Wrap"
                                  Text="{Binding TopCategoryText, StringFormat='Top category: {0}'}" />
                </StackPanel>
            </ui:Card>

            <ui:Card Grid.Column="3" MinHeight="92" VerticalAlignment="Stretch" Margin="0,0,0,0">
                <StackPanel Margin="6" VerticalAlignment="Stretch">
                    <ui:TextBlock FontTypography="BodyStrong" Text="Insights" Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{Binding Insights}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,2" Text="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ui:Card>
        </Grid>


        <!-- Income vs expense chart -->
        <ui:Card Grid.Row="2" Margin="0,0,0,10" Height="210">
            <StackPanel>
                <ui:TextBlock FontTypography="BodyStrong" Text="Income vs expense trend (last 6 months)" Margin="0,0,0,4" />
                <lvc:CartesianChart Height="160" Series="{Binding IncomeExpenseSeries}" XAxes="{Binding IncomeExpenseAxes}"
                                    LegendPosition="Right" />
            </StackPanel>
        </ui:Card>

        <!-- Filter bar -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <ui:TextBox x:Name="SearchBox" PlaceholderText="Search" Width="160" Margin="0,0,8,0"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" TextChanged="OnSearchTextChanged" />
                <ComboBox Width="180" Margin="0,0,8,0" ItemsSource="{Binding CategoryFilters}"
                          DisplayMemberPath="Text" SelectedItem="{Binding SelectedCategory}" />
                <DatePicker Width="130" Margin="0,0,8,0" SelectedDate="{Binding FromDate}" />
                <DatePicker Width="130" Margin="0,0,8,0" SelectedDate="{Binding ToDate}" />
                <ui:TextBox PlaceholderText="Min" Width="80" Margin="0,0,8,0"
                            Text="{Binding MinAmountText, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBox PlaceholderText="Max" Width="80" Margin="0,0,8,0"
                            Text="{Binding MaxAmountText, UpdateSourceTrigger=PropertyChanged}" />
                <ui:Button Content="Apply" Margin="0,0,8,0" Click="OnApplyFilter" Appearance="Primary" />
                <ui:Button Content="Clear" Click="OnClearFilter" Appearance="Secondary" />
            </StackPanel>
        </Grid>

        <!-- History -->
        <DataGrid Grid.Row="4" x:Name="ExpenseGrid" ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" RowHeight="42" EnableRowVirtualization="True"
                  PreviewMouseLeftButtonDown="OnExpenseGridPreviewMouseLeftButtonDown">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Background" Value="#F8FAFC" />
                </Style>
</DataGrid.Resources>
            <DataGrid.Columns>

                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="120" />
                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="*" />
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='₹{0:N2}'}" Width="140" />
                <DataGridTextColumn Header="Spent by" Binding="{Binding SpentBy}" Width="140" />
                <DataGridTextColumn Header="Spent for" Binding="{Binding SpentFor}" Width="*" />
                <DataGridTemplateColumn Header="Recurring" Width="110">

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                                <CheckBox IsChecked="{Binding IsRecurring, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="True" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
<DataGridTemplateColumn Header="Actions" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:Button Appearance="Transparent" Padding="6" Margin="0,0,6,0"
                                           Tag="{Binding Id}" Click="OnBills">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="Receipt24" />
                                    </ui:Button.Icon>
                                </ui:Button>

                                <ui:Button Appearance="Transparent" Padding="6" Margin="0,0,6,0"
                                           Tag="{Binding Id}" Click="OnEditExpense">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="Edit24" />
                                    </ui:Button.Icon>
                                </ui:Button>

                                <ui:Button Appearance="Transparent" Padding="6"
                                           Tag="{Binding Id}" Click="OnDeleteExpense">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="Delete24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
