<Page x:Class="Richie.UI.Views.Pages.HelpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Title="Help &amp; About"
      ScrollViewer.CanContentScroll="False">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel MaxWidth="760" HorizontalAlignment="Left">
                <ui:TextBlock FontTypography="TitleLarge" Text="Help &amp; About" Foreground="White" Margin="0,0,0,12" />

                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="User guide" Margin="0,0,0,6" />
                        <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap"
                                      Text="• Assets — add holdings (the form adapts per type), track SIPs, link goals, attach documents, and see allocation &amp; P&amp;L.&#10;• Expenses — log spending and income, set budgets, and view analytics; attach bills to any expense.&#10;• Password Vault — re-authenticate each time; reveal/copy needs your master password; copies auto-clear after 30s.&#10;• Financial Health Audit — health &amp; risk scores, benchmark comparison, compliance and insurance coverage.&#10;• Reports &amp; Export — generate PDF/PPTX reports; unmasked password export is gated.&#10;• Settings — theme, auto-lock, notifications, budgets, jewellery toggle." />
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="FAQs" Margin="0,0,0,6" />
                        <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap"
                                      Text="Q: Is my data sent anywhere?  A: No — Richie is fully offline; everything stays encrypted on this device.&#10;Q: I forgot my vault master password.  A: Use 'Forgot master password?' on the vault if you enabled security-question recovery.&#10;Q: Can I disable encryption?  A: No — the database and vault are always encrypted.&#10;Q: How do I back up?  A: Profile menu → Backup &amp; restore." />
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="App tour" Margin="0,0,0,6" />
                        <ui:Button Content="Replay app tour" Click="OnReplayTour" HorizontalAlignment="Left" />
                    </StackPanel>
                </ui:Card>

                <ui:Card>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="About" Margin="0,0,0,6" />
                        <ui:TextBlock Appearance="Secondary" Text="Richie — offline-first personal finance for Windows." />
                        <ui:TextBlock x:Name="VersionTextBlock" Appearance="Secondary" />
                        <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,6,0,0"
                                      Text="Tech: .NET 10 · WPF + WPF-UI (Fluent) · EF Core / SQLite + SQLCipher · LiveCharts2 · QuestPDF · OpenXML." />
                        <ui:TextBlock Appearance="Secondary" Margin="0,6,0,0" Text="Contact: the Richie team." />
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
