<Page x:Class="Richie.UI.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      mc:Ignorable="d"
      Title="Dashboard"
      ScrollViewer.CanContentScroll="False"
      Loaded="OnLoaded"
      Unloaded="OnUnloaded">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <!-- Hero greeting: date · greeting · portfolio insight · mini-calendar · live clock -->
            <ui:Card Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="{Binding HeroDateText}" />
                        <ui:TextBlock FontTypography="TitleLarge" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,2,0,0" Text="{Binding GreetingText}" />
                        <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,6,12,0"
                                      Text="{Binding PortfolioInsightText}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <ui:TextBlock x:Name="ClockText" FontTypography="TitleLarge" Foreground="{DynamicResource TextFillColorPrimaryBrush}" HorizontalAlignment="Right" />
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                      HorizontalAlignment="Right" Text="Local time" />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Summary cards -->
            <Grid Margin="0,0,0,12" Height="130">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <!-- Total Assets -->
<ui:Card Grid.Column="0" Padding="12" Height="100">
    <StackPanel VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8">
            <ui:SymbolIcon Symbol="Wallet24"
                           FontSize="16"
                           Foreground="{StaticResource BrandPrimaryBrush}"
                           Margin="0,0,6,0"/>
            <ui:TextBlock Appearance="Secondary"
                          FontTypography="Caption"
                          VerticalAlignment="Center"
                          Text="Total assets"/>
        </StackPanel>

        <ui:TextBlock FontTypography="Subtitle"
                      Text="{Binding TotalAssetsText}"
                      HorizontalAlignment="Center"/>
    </StackPanel>
</ui:Card>

<!-- Total Invested -->
<ui:Card Grid.Column="2" Padding="12" Height="100">
    <StackPanel VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8">
            <ui:SymbolIcon Symbol="Savings24"
                           FontSize="16"
                           Foreground="{StaticResource BrandPrimaryBrush}"
                           Margin="0,0,6,0"/>
            <ui:TextBlock Appearance="Secondary"
                          FontTypography="Caption"
                          VerticalAlignment="Center"
                          Text="Total invested"/>
        </StackPanel>

        <ui:TextBlock FontTypography="Subtitle"
                      Text="{Binding TotalInvestedText}"
                      HorizontalAlignment="Center"/>
    </StackPanel>
</ui:Card>

<!-- Expenses -->
<ui:Card Grid.Column="4" Padding="12" Height="100">
    <StackPanel VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8">
            <ui:SymbolIcon Symbol="ReceiptMoney24"
                           FontSize="16"
                           Foreground="{StaticResource BrandPrimaryBrush}"
                           Margin="0,0,6,0"/>
            <ui:TextBlock Appearance="Secondary"
                          FontTypography="Caption"
                          VerticalAlignment="Center"
                          Text="Expenses (this month)"/>
        </StackPanel>

        <ui:TextBlock FontTypography="Subtitle"
                      Text="{Binding TotalExpensesText}"
                      HorizontalAlignment="Center"/>
    </StackPanel>
</ui:Card>

<!-- Profit & Loss -->
<ui:Card Grid.Column="6" Padding="12" Height="100">
    <StackPanel VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8">
            <ui:SymbolIcon Symbol="DataTrending24"
                           FontSize="16"
                           Foreground="{Binding ProfitLossBrush}"
                           Margin="0,0,6,0"/>
            <ui:TextBlock Appearance="Secondary"
                          FontTypography="Caption"
                          VerticalAlignment="Center"
                          Text="Profit &amp; loss"/>
        </StackPanel>

        <ui:TextBlock FontTypography="Subtitle"
                      Foreground="{Binding ProfitLossBrush}"
                      Text="{Binding ProfitLossText}"
                      HorizontalAlignment="Center"/>
    </StackPanel>
</ui:Card>

<!-- Financial Health -->
<ui:Card Grid.Column="8" Padding="12" Height="100">
    <StackPanel VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8">
            <ui:SymbolIcon Symbol="HeartPulse24"
                           FontSize="16"
                           Foreground="{Binding HealthBrush}"
                           Margin="0,0,6,0"/>
            <ui:TextBlock Appearance="Secondary"
                          FontTypography="Caption"
                          VerticalAlignment="Center"
                          Text="Financial health"/>
        </StackPanel>

        <ui:TextBlock FontTypography="Subtitle"
                      Foreground="{Binding HealthBrush}"
                      Text="{Binding HealthScoreText}"
                      HorizontalAlignment="Center"/>

        
    </StackPanel>
</ui:Card>
            </Grid>

            <!-- Quick actions -->
            <WrapPanel Margin="0,0,0,12">
                <ui:Button Content="Add asset" Appearance="Primary" Margin="0,0,8,8" Click="OnAddAsset" />
                <ui:Button Content="Add expense" Margin="0,0,8,8" Click="OnAddExpense" />
                <ui:Button Content="Add password" Margin="0,0,8,8" Click="OnAddPassword" />
                <ui:Button Content="Generate report" Margin="0,0,0,8" Click="OnGenerateReport" />
            </WrapPanel>

            <!-- Charts row 1: Asset allocation + Income vs Expense -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Height="300">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Asset allocation" />
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="By value" Margin="0,0,0,8" />
                        <Grid Visibility="{Binding HasAssets, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <lvc:PieChart Grid.Column="0" Height="220" Series="{Binding AllocationSeries}"
                                          LegendPosition="Hidden" />
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding AllocationLegend}"
                                          VerticalAlignment="Center" Margin="10,0,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <Ellipse Width="10" Height="10" Fill="{Binding Swatch}"
                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <ui:TextBlock FontTypography="Caption" VerticalAlignment="Center"
                                                          Text="{Binding Label}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                        <ui:TextBlock Appearance="Secondary" Text="Add assets to see your allocation."
                                      Visibility="{Binding NoAssets, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="2" Height="300">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Income vs Expense" />
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="Last 9 months" Margin="0,0,0,8" />
                        <lvc:CartesianChart Height="220" Series="{Binding IncomeExpenseSeries}"
                                            XAxes="{Binding IncomeExpenseAxes}"
                                            YAxes="{Binding IncomeExpenseYAxes}"
                                            LegendPosition="Bottom" />
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- Charts row 2: Investment growth + Expense breakdown -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Height="300">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <ui:TextBlock FontTypography="BodyStrong" Text="Investment growth" />
                                <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="Invested capital over time" />
                            </StackPanel>
                            <ui:TextBlock Grid.Column="1" VerticalAlignment="Center" FontTypography="BodyStrong"
                                          Foreground="{StaticResource BrandSuccessBrush}" Text="{Binding InvestmentGrowthText}"
                                          Visibility="{Binding HasAssets, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <lvc:CartesianChart Height="210" Margin="0,8,0,0" Series="{Binding InvestmentSeries}"
                                            XAxes="{Binding InvestmentAxes}"
                                            YAxes="{Binding InvestmentYAxes}"
                                            Visibility="{Binding HasAssets, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <ui:TextBlock Appearance="Secondary" Margin="0,8,0,0" Text="Add assets to track investment growth."
                                      Visibility="{Binding NoAssets, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="2" Height="300">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Expense breakdown" />
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="This month" Margin="0,0,0,8" />
                       <lvc:CartesianChart Height="220" Series="{Binding ExpenseBreakdownSeries}"
                                            YAxes="{Binding ExpenseBreakdownAxes}"
                                            XAxes="{Binding ExpenseBreakdownYAxes}" />
                        <ItemsControl ItemsSource="{Binding ExpenseBreakdownLegend}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <Border Width="12" Height="12" Background="{Binding Swatch}" CornerRadius="2" Margin="0,0,6,0" />
                                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" Text="{Binding Label}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- Insights (horizontal) -->
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="Insights" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Insights}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,8,0" Padding="12" CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                    <DockPanel>
                                        <ui:Button DockPanel.Dock="Bottom" HorizontalAlignment="Left" Margin="0,8,0,0"
                                                   Padding="10,2" Appearance="Secondary"
                                                   Content="{Binding ActionLabel}" Click="OnInsightAction" />
                                        <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Text="{Binding Text}" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ui:TextBlock Appearance="Secondary"
                                  Text="No insights yet — add assets and expenses to see conclusions here."
                                  Visibility="{Binding NoInsights, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </ui:Card>

            <!-- Upcoming SIPs -->
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="Upcoming SIPs (next 30 days)" Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding UpcomingSips}"
                                      Visibility="{Binding HasUpcomingSips, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <ui:TextBlock Text="{Binding AssetName}" />
                                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                                          Text="{Binding FrequencyText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <ui:TextBlock HorizontalAlignment="Right" Text="{Binding AmountText}" />
                                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                                          HorizontalAlignment="Right" Text="{Binding DueText}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ui:TextBlock Appearance="Secondary" Text="No SIPs due in the next 30 days."
                                      Visibility="{Binding NoUpcomingSips, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </ui:Card>

            <!-- Recent activity -->
            <ui:Card>
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="Recent activity" Margin="0,0,0,6" />
                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasActivity, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding RecentActivity}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Action marker: green=Added, amber=Updated, red=Deleted -->
                                        <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource BrandWarningBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Action}" Value="Added">
                                                            <Setter Property="Fill" Value="{StaticResource BrandSuccessBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Action}" Value="Deleted">
                                                            <Setter Property="Fill" Value="{StaticResource BrandDangerBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <ui:TextBlock Grid.Column="1" Appearance="Secondary" FontTypography="Caption"
                                                      VerticalAlignment="Center" Text="{Binding DateText}" />
                                        <ui:TextBlock Grid.Column="2" FontTypography="Caption" VerticalAlignment="Center"
                                                      Text="{Binding Module}" />
                                        <ui:TextBlock Grid.Column="3" Appearance="Secondary" FontTypography="Caption" TextWrapping="Wrap"
                                                      VerticalAlignment="Center" Text="{Binding Description}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <ui:TextBlock Appearance="Secondary" Text="No activity yet."
                                  Visibility="{Binding NoActivity, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
