<Page x:Class="Richie.UI.Views.Pages.PasswordVaultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Title="Password Vault"
      Loaded="OnLoaded">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid Margin="24">

        <!-- Locked / setup gate -->
        <Grid Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}">
            <ui:Card MaxWidth="420" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                <StackPanel>
                    <ui:SymbolIcon Symbol="LockClosed24" FontSize="32" HorizontalAlignment="Center" />
                    <ui:TextBlock FontTypography="TitleLarge" TextAlignment="Center" Foreground="White" Margin="0,12,0,4"
                                  Text="{Binding GateHeading}" />
                    <ui:TextBlock Appearance="Secondary" TextAlignment="Center" TextWrapping="Wrap"
                                  Margin="0,0,0,16" Text="{Binding GateDescription}" />
                    <ui:PasswordBox x:Name="MasterPasswordBox" PlaceholderText="Master password"
                                    Password="{Binding MasterPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    KeyDown="OnMasterPasswordKeyDown" />
                    <ui:TextBlock Foreground="#C42B1C" TextWrapping="Wrap" Margin="0,8,0,0"
                                  Text="{Binding Error}" />
                    <ui:Button Content="{Binding SubmitText}" Appearance="Primary" Margin="0,16,0,0"
                               HorizontalAlignment="Stretch" Click="OnSubmit" />
                    <ui:Button Content="Forgot master password?" Appearance="Transparent" Margin="0,8,0,0"
                               HorizontalAlignment="Center" Click="OnForgotMasterPassword"
                               Visibility="{Binding RecoveryAvailable, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </ui:Card>
        </Grid>

        <!-- Unlocked vault -->
        <Grid Visibility="{Binding IsUnlocked, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBlock Grid.Column="0" FontTypography="TitleLarge" Text="Password Vault"
                              Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Password health" Margin="0,0,8,0" Click="OnPasswordHealth" />
                    <ui:Button Content="Bulk upload" Margin="0,0,8,0" Click="OnBulkUpload" />
                    <ui:Button Content="Master password" Margin="0,0,8,0" Click="OnVaultSecurity" />
                    <ui:Button Content="Lock" Margin="0,0,8,0" Click="OnLock" />
                    <ui:Button Content="Add password" Appearance="Primary" Click="OnAddEntry" />
                </StackPanel>
            </Grid>

            <!-- Search + category filter -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                <ui:TextBox PlaceholderText="Search account / user id / URL" Width="260" Margin="0,0,8,0"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <ComboBox Width="200" ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}" />
            </StackPanel>

            <DataGrid Grid.Row="2" ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Account" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                    <Hyperlink Click="OnAccountLinkClick" Tag="{Binding Url}"
                                               ToolTip="{Binding Url}">
                                        <Hyperlink.Style>
                                            <Style TargetType="Hyperlink">
                                                <Style.Triggers>
                                                    <!-- No URL → render as plain, non-clickable text. -->
                                                    <DataTrigger Binding="{Binding Url}" Value="{x:Null}">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                        <Setter Property="TextDecorations" Value="{x:Null}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Hyperlink.Style>
                                        <!-- Run.Text binds TwoWay by default; force OneWay (read-only source). -->
                                        <Run Text="{Binding AccountName, Mode=OneWay}" />
                                    </Hyperlink>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="Auto" />
                    <DataGridTextColumn Header="User ID" Binding="{Binding LoginId}" Width="*" />
                    <DataGridTemplateColumn Header="Password" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayPassword}" VerticalAlignment="Center"
                                               MinWidth="90" FontFamily="Consolas" />
                                    <ui:Button Appearance="Transparent" Padding="6,2" Margin="6,0,0,0"
                                               Tag="{Binding}" Click="OnReveal" ToolTip="{Binding EyeTooltip}">
                                        <ui:SymbolIcon Symbol="{Binding EyeSymbol}" />
                                    </ui:Button>
                                    <ui:Button Appearance="Transparent" Padding="6,2" Margin="2,0,0,0"
                                               Tag="{Binding}" Click="OnCopy" ToolTip="Copy password">
                                        <ui:SymbolIcon Symbol="Copy24" />
                                    </ui:Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button Content="Edit" Padding="8,2" Margin="0,0,4,0"
                                               Tag="{Binding Id}" Click="OnEditEntry" />
                                    <ui:Button Content="Delete" Padding="8,2"
                                               Tag="{Binding Id}" Click="OnDeleteEntry" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Toast host (copy confirmation etc.) -->
        <ui:SnackbarPresenter x:Name="VaultSnackbar" />
    </Grid>
</Page>
