<ui:FluentWindow x:Class="Richie.UI.Views.Vault.VaultHealthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Password health"
        Height="600" Width="640"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Password health" />

        <StackPanel Grid.Row="1" Margin="24,8,24,0">
            <ui:Card>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                        <ui:TextBlock FontTypography="Display" Foreground="{Binding RatingBrush}"
                                      Text="{Binding Score}" />
                        <ui:TextBlock Appearance="Secondary" HorizontalAlignment="Center" Text="/ 100" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <ui:TextBlock FontTypography="Subtitle" Foreground="{Binding RatingBrush}"
                                      Text="{Binding Rating}" />
                        <ui:TextBlock Appearance="Secondary" Margin="0,4,0,0" Text="{Binding SummaryText}" />
                        <ui:TextBlock Appearance="Secondary" FontTypography="Caption" TextWrapping="Wrap"
                                      Margin="0,8,0,0" Text="{Binding ScaleLegend}" />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <ui:TextBlock Appearance="Secondary" FontTypography="Caption" TextWrapping="Wrap"
                          Margin="2,10,2,6" Text="{Binding ScoringExplanation}" />

            <ui:TextBlock FontTypography="BodyStrong" Margin="2,6,0,4" Text="Needs attention" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="24,0,24,16">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Visibility="{Binding HasIssues, Converter={StaticResource BoolToVisibilityConverter}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="*" />
                    <DataGridTextColumn Header="Issues" Binding="{Binding IssuesText}" Width="2*" />
                    <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="Auto" />
                </DataGrid.Columns>
            </DataGrid>

            <ui:TextBlock Appearance="Secondary" VerticalAlignment="Top"
                          Text="No issues found — every credential is strong, unique, and recent."
                          Visibility="{Binding NoIssues, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Grid>
</ui:FluentWindow>
