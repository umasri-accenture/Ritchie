<ui:FluentWindow x:Class="Richie.UI.Views.Insurance.InsuranceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Insurance &amp; Protection"
        Height="560" Width="820"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Insurance &amp; Protection" />

        <Grid Grid.Row="1" Margin="24,8,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBlock Grid.Column="0" FontTypography="BodyStrong" VerticalAlignment="Center"
                          TextTrimming="CharacterEllipsis" Margin="0,0,8,0"
                          Text="Your policies (not part of asset allocation)" />
            <ui:Button Grid.Column="1" HorizontalAlignment="Right" Content="Add policy" Appearance="Primary" Click="OnAddPolicy" />
        </Grid>

        <DataGrid Grid.Row="2" Margin="24,0,24,16" ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="Auto" />
                <DataGridTextColumn Header="Policy" Binding="{Binding PolicyName}" Width="*" />
                <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="*" />
                <DataGridTextColumn Header="Coverage" Binding="{Binding CoverageAmount, StringFormat='₹{0:N0}'}" Width="Auto" />
                <DataGridTextColumn Header="Premium/yr" Binding="{Binding AnnualPremium, StringFormat='₹{0:N0}'}" Width="Auto" />
                <DataGridTextColumn Header="Renewal" Binding="{Binding RenewalDate, StringFormat=d}" Width="Auto" />
                <DataGridTextColumn Header="Days left" Binding="{Binding DaysToRenewal}" Width="Auto" />
                <DataGridTemplateColumn Header="Actions" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="Edit" Padding="8,2" Margin="0,0,4,0"
                                           Tag="{Binding Id}" Click="OnEditPolicy" />
                                <ui:Button Content="Delete" Padding="8,2"
                                           Tag="{Binding Id}" Click="OnDeletePolicy" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <ui:TextBlock Grid.Row="2" Margin="24" VerticalAlignment="Top" Appearance="Secondary"
                      Text="No policies yet. Add your health, term-life, vehicle and home cover to track renewals and coverage gaps."
                      TextWrapping="Wrap"
                      Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />
    </Grid>
</ui:FluentWindow>
