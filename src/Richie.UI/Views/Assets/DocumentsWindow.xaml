<ui:FluentWindow x:Class="Richie.UI.Views.Assets.DocumentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Documents"
        Height="640" Width="820"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        
        <!-- Overrides to replace every red accent with Primary: #2563EB -->
        <Color x:Key="SystemAccentColor">#2563EB</Color>
        <SolidColorBrush x:Key="SystemAccentColorBrush" Color="#2563EB" />
        <Color x:Key="SystemAccentColorLight1">#3B82F6</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight1Brush" Color="#3B82F6" />
        <Color x:Key="SystemAccentColorLight2">#60A5FA</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight2Brush" Color="#60A5FA" />
        <Color x:Key="SystemAccentColorLight3">#93C5FD</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight3Brush" Color="#93C5FD" />
        
        <Color x:Key="SystemAccentColorDark1">#1D4ED8</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark1Brush" Color="#1D4ED8" />
        <Color x:Key="SystemAccentColorDark2">#1E40AF</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark2Brush" Color="#1E40AF" />
        <Color x:Key="SystemAccentColorDark3">#1E3A8A</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark3Brush" Color="#1E3A8A" />

        <!-- Custom button style to guarantee blue fill state by default, hover, and press -->
        <Style x:Key="BluePrimaryButtonStyle" TargetType="ui:Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ui:Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E3A8A" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E3A8A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Documents" />

        <Grid Grid.Row="1" Margin="24,8,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- List + actions -->
            <DockPanel Grid.Column="0">
                <ui:TextBlock DockPanel.Dock="Top" FontTypography="TitleLarge" Text="{Binding AssetName}" Margin="0,0,0,8" />
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:Button Content="Attach file" Style="{StaticResource BluePrimaryButtonStyle}" Click="OnAttach" Margin="0,0,8,0" />
                    <ui:Button Content="Delete" Click="OnDelete" />
                </StackPanel>
                <ui:TextBlock DockPanel.Dock="Bottom" Appearance="Secondary" FontTypography="Caption"
                              TextWrapping="Wrap" Margin="0,8,0,0"
                              Text="Previewable: PNG, JPG, JPEG, BMP, GIF, WEBP. Other files (e.g. PDF): use Download." />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                    <ui:Button Content="Previous" Click="OnPrevious" Margin="0,0,8,0" IsEnabled="{Binding HasMultiple}" />
                    <ui:Button Content="Next" Click="OnNext" IsEnabled="{Binding HasMultiple}" />
                </StackPanel>
                <ui:TextBlock DockPanel.Dock="Bottom" Appearance="Secondary" Margin="0,8,0,0"
                              Text="No documents yet."
                              Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />
                <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedDocument}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2">
                                <ui:TextBlock Text="{Binding FileName}" />
                                <ui:TextBlock Appearance="Secondary" FontSize="11">
                                    <Run Text="{Binding Kind, Mode=OneWay}" />
                                    <Run Text="{Binding SizeBytes, Mode=OneWay, StringFormat=' · {0:N0} bytes'}" />
                                </ui:TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Preview -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                <Grid Margin="12">
                    <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Text="{Binding PreviewMessage}" />
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                    <ui:Button Content="Download" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                               Click="OnDownload" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
