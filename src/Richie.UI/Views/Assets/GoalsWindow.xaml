<ui:FluentWindow x:Class="Richie.UI.Views.Assets.GoalsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Financial goals"
        Height="680" Width="560"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <!-- Overrides to replace every red accent with Primary: #2563EB -->
        <Color x:Key="SystemAccentColor">#2563EB</Color>
        <SolidColorBrush x:Key="SystemAccentColorBrush" Color="#2563EB" />
        <Color x:Key="SystemAccentColorLight1">#3B82F6</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight1Brush" Color="#3B82F6" />
        <Color x:Key="SystemAccentColorLight2">#60A5FA</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight2Brush" Color="#60A5FA" />
        <Color x:Key="SystemAccentColorLight3">#93C5FD</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight3Brush" Color="#93C5FD" />
        
        <Color x:Key="SystemAccentColorDark1">#1D4ED8</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark1Brush" Color="#1D4ED8" />
        <Color x:Key="SystemAccentColorDark2">#1E40AF</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark2Brush" Color="#1E40AF" />
        <Color x:Key="SystemAccentColorDark3">#1E3A8A</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark3Brush" Color="#1E3A8A" />

        <!-- Custom button style to guarantee blue fill state by default, hover, and press -->
        <Style x:Key="BluePrimaryButtonStyle" TargetType="ui:Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ui:Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E3A8A" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E3A8A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
     </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Financial goals" />

        <Grid Grid.Row="1" Margin="24,8,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBlock Grid.Column="0" FontTypography="TitleLarge" Text="Goals"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                <ui:Button Grid.Column="1" Content="Add goal" Style="{StaticResource BluePrimaryButtonStyle}" HorizontalAlignment="Right" Click="OnAddGoal" />
            </Grid>

            <ui:TextBlock Grid.Row="1" Appearance="Secondary" VerticalAlignment="Top"
                          Text="No goals yet. Add one and link the assets that contribute to it."
                          Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <ui:TextBlock FontTypography="BodyStrong" Text="{Binding Name}" VerticalAlignment="Center" />
                                        <ui:TextBlock Appearance="Secondary" HorizontalAlignment="Right" Text="{Binding PriorityText}" />
                                    </Grid>
                                    <ProgressBar Value="{Binding Percent, Mode=OneWay}" Maximum="100" Height="6" Margin="0,8" />
                                    <ui:TextBlock Appearance="Secondary" Text="{Binding PercentText}" />
                                    <Grid Margin="0,4,0,0">
                                        <ui:TextBlock Appearance="Secondary" Text="{Binding CurrentText}" HorizontalAlignment="Left" />
                                        <ui:TextBlock Appearance="Secondary" Text="{Binding TargetText}" HorizontalAlignment="Right" />
                                    </Grid>
                                    <ui:TextBlock Appearance="Secondary" Text="{Binding GapText}" Margin="0,2,0,0" />
                                    <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,6,0,0" Text="{Binding ProjectedText}" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                        <ui:Button Content="Edit" Padding="8,2" Margin="0,0,4,0" Tag="{Binding Id}" Click="OnEditGoal" />
                                        <ui:Button Content="Delete" Padding="8,2" Tag="{Binding Id}" Click="OnDeleteGoal" />
                                    </StackPanel>
                                </StackPanel>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
