<ui:FluentWindow x:Class="Richie.UI.Views.Assets.GoalsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Financial goals"
        Height="680" Width="560"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Financial goals" />

        <Grid Grid.Row="1" Margin="24,8,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBlock Grid.Column="0" FontTypography="TitleLarge" Text="Goals"
                              VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                <ui:Button Grid.Column="1" Content="Add goal" Appearance="Primary" HorizontalAlignment="Right" Click="OnAddGoal" />
            </Grid>

            <ui:TextBlock Grid.Row="1" Appearance="Secondary" VerticalAlignment="Top"
                          Text="No goals yet. Add one and link the assets that contribute to it."
                          Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <ui:TextBlock FontTypography="BodyStrong" Text="{Binding Name}" VerticalAlignment="Center" />
                                        <ui:TextBlock Appearance="Secondary" HorizontalAlignment="Right" Text="{Binding PriorityText}" />
                                    </Grid>
                                    <ProgressBar Value="{Binding Percent, Mode=OneWay}" Maximum="100" Height="6" Margin="0,8" />
                                    <ui:TextBlock Appearance="Secondary" Text="{Binding PercentText}" />
                                    <Grid Margin="0,4,0,0">
                                        <ui:TextBlock Appearance="Secondary" Text="{Binding CurrentText}" HorizontalAlignment="Left" />
                                        <ui:TextBlock Appearance="Secondary" Text="{Binding TargetText}" HorizontalAlignment="Right" />
                                    </Grid>
                                    <ui:TextBlock Appearance="Secondary" Text="{Binding GapText}" Margin="0,2,0,0" />
                                    <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,6,0,0" Text="{Binding ProjectedText}" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                        <ui:Button Content="Edit" Padding="8,2" Margin="0,0,4,0" Tag="{Binding Id}" Click="OnEditGoal" />
                                        <ui:Button Content="Delete" Padding="8,2" Tag="{Binding Id}" Click="OnDeleteGoal" />
                                    </StackPanel>
                                </StackPanel>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
