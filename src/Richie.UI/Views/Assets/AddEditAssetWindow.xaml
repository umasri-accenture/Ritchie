<ui:FluentWindow x:Class="Richie.UI.Views.Assets.AddEditAssetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Asset"
        Height="720" Width="520"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <!-- Overrides to replace every red accent with Primary: #2563EB -->
        <Color x:Key="SystemAccentColor">#2563EB</Color>
        <SolidColorBrush x:Key="SystemAccentColorBrush" Color="#2563EB" />
        <Color x:Key="SystemAccentColorLight1">#3B82F6</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight1Brush" Color="#3B82F6" />
        <Color x:Key="SystemAccentColorLight2">#60A5FA</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight2Brush" Color="#60A5FA" />
        <Color x:Key="SystemAccentColorLight3">#93C5FD</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight3Brush" Color="#93C5FD" />
        
        <Color x:Key="SystemAccentColorDark1">#1D4ED8</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark1Brush" Color="#1D4ED8" />
        <Color x:Key="SystemAccentColorDark2">#1E40AF</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark2Brush" Color="#1E40AF" />
        <Color x:Key="SystemAccentColorDark3">#1E3A8A</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark3Brush" Color="#1E3A8A" />

        <!-- Custom button style to guarantee blue fill state by default, hover, and press -->
        <Style x:Key="BluePrimaryButtonStyle" TargetType="ui:Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ui:Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E3A8A" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E3A8A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding Title}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,8">
            <StackPanel>
                <ui:TextBlock Text="Asset type" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Types}" DisplayMemberPath="Text" SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedType}" Margin="0,0,0,12" />

                <ui:TextBox PlaceholderText="Asset name" Margin="0,0,0,10"
                            Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <ui:TextBox PlaceholderText="ISIN / Stock ticker" Margin="0,0,0,10"
                            Visibility="{Binding ShowIdentifier, Converter={StaticResource BoolToVis}}"
                            Text="{Binding Identifier, UpdateSourceTrigger=PropertyChanged}" />

                <ui:TextBox PlaceholderText="Exchange" Margin="0,0,0,10"
                            Visibility="{Binding ShowExchange, Converter={StaticResource BoolToVis}}"
                            Text="{Binding Exchange, UpdateSourceTrigger=PropertyChanged}" />

                <ui:TextBlock Text="Investment start date" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding InvestmentStartDate}" Margin="0,0,0,10" />

                <ui:TextBox PlaceholderText="Invested amount" Margin="0,0,0,10"
                            Text="{Binding InvestedAmountText, UpdateSourceTrigger=PropertyChanged}" />

                <ui:TextBox PlaceholderText="Quantity / Units / Grams" Margin="0,0,0,10"
                            Visibility="{Binding ShowQuantityPrice, Converter={StaticResource BoolToVis}}"
                            Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBox PlaceholderText="Purchase price per unit" Margin="0,0,0,10"
                            Visibility="{Binding ShowQuantityPrice, Converter={StaticResource BoolToVis}}"
                            Text="{Binding PurchasePriceText, UpdateSourceTrigger=PropertyChanged}" />

                <ui:TextBox PlaceholderText="Issue price" Margin="0,0,0,10"
                            Visibility="{Binding ShowIssuePrice, Converter={StaticResource BoolToVis}}"
                            Text="{Binding IssuePriceText, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Visibility="{Binding ShowMaturityDate, Converter={StaticResource BoolToVis}}">
                    <ui:TextBlock Text="Maturity date" Margin="0,0,0,4" />
                    <DatePicker SelectedDate="{Binding MaturityDate}" Margin="0,0,0,10" />
                </StackPanel>

                <ui:TextBox PlaceholderText="Platform name" Margin="0,0,0,10"
                            Visibility="{Binding ShowPlatform, Converter={StaticResource BoolToVis}}"
                            Text="{Binding PlatformName, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Visibility="{Binding ShowRealEstate, Converter={StaticResource BoolToVis}}">
                    <ui:TextBox PlaceholderText="Property address" Margin="0,0,0,10"
                                Text="{Binding PropertyAddress, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:TextBox PlaceholderText="Area (sq ft)" Margin="0,0,0,10"
                                Text="{Binding AreaText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Visibility="{Binding ShowJewellery, Converter={StaticResource BoolToVis}}">
                    <ui:TextBox PlaceholderText="Weight (grams)" Margin="0,0,0,10"
                                Text="{Binding WeightText, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:TextBox PlaceholderText="Purity (e.g. 22K)" Margin="0,0,0,10"
                                Text="{Binding Purity, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:TextBox PlaceholderText="Appraiser name" Margin="0,0,0,10"
                                Text="{Binding AppraiserName, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Content="Exclude from portfolio valuation" Margin="0,0,0,10"
                               IsChecked="{Binding IsExcludedFromPortfolio}" />
                </StackPanel>

                <StackPanel Visibility="{Binding ShowPolicy, Converter={StaticResource BoolToVis}}">
                    <ui:TextBox PlaceholderText="Policy number" Margin="0,0,0,10"
                                Text="{Binding PolicyNumber, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:TextBox PlaceholderText="Guaranteed return %" Margin="0,0,0,10"
                                Text="{Binding GuaranteedReturnText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <ui:TextBox PlaceholderText="Current value" Margin="0,0,0,10"
                            Text="{Binding CurrentValueText, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBlock Text="Valuation date" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding ValuationDate}" Margin="0,0,0,10" />

                <CheckBox Content="Recurring investment (SIP)" Margin="0,0,0,10" IsChecked="{Binding IsSip}" />

                <ui:TextBox PlaceholderText="Notes" Margin="0,0,0,10" AcceptsReturn="True" MinLines="2"
                            Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

                <ui:TextBlock Foreground="#C42B1C" TextWrapping="Wrap" Text="{Binding Error}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,8,24,16">
            <ui:Button Content="Cancel" Margin="0,0,8,0" Command="{Binding CancelCommand}" />
            <ui:Button Content="Save" Style="{StaticResource BluePrimaryButtonStyle}" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
